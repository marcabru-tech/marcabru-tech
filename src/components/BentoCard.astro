---
const { title, icon = '', cols = 'md:col-span-1' } = Astro.props;
---
<div class={`relative rounded-2xl border border-white/[0.06] bg-panel p-6 shadow-glass backdrop-blur-xl ${cols} flex flex-col gap-3 transition-transform duration-200 hover:-translate-y-1`}>
  {icon && <span class="text-2xl" aria-hidden="true">{icon}</span>}
  {title && <h2 class="text-lg font-semibold text-accent">{title}</h2>}
  <div class="text-sm text-muted leading-relaxed">
    <slot />
  </div>
</div>
